{
  "name": "chitchatter",
  "version": "0.0.0",
  "homepage": "https://t1nky.github.io/chitchatter/",
  "author": "Jeremy Kahn <me@jeremyckahn.com>",
  "license": "GPL-2.0-or-later",
  "type": "module",
  "dependencies": {
    "@fontsource-variable/inter": "^5.2.8",
    "@hugeicons/core-free-icons": "^4.0.0",
    "@hugeicons/react": "^1.1.6",
    "@react-hook/debounce": "^4.0.0",
    "@react-hook/window-size": "^3.1.1",
    "@tanstack/react-query": "^5.90.19",
    "@testing-library/react": "^15.0.7",
    "@testing-library/user-event": "^14.6.1",
    "buffer": "^6.0.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "file-saver": "^2.0.5",
    "fun-animal-names": "^0.1.1",
    "i18next": "^25.8.18",
    "localforage": "^1.10.0",
    "radix-ui": "^1.4.3",
    "random-word-slugs": "^0.1.7",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-git-info": "^2.0.1",
    "react-hotkeys-hook": "^4.6.2",
    "react-i18next": "^16.5.8",
    "react-markdown": "^9.1.0",
    "react-qrcode-logo": "^2.10.0",
    "react-router-dom": "^7.12.0",
    "react-syntax-highlighter": "^16.1.0",
    "react-youtube": "^10.1.0",
    "remark-gfm": "^4.0.1",
    "sdp": "^3.2.1",
    "secure-file-transfer": "^0.0.8",
    "shadcn": "^4.0.8",
    "stream-browserify": "^3.0.0",
    "streamsaver": "^2.0.6",
    "tailwind-merge": "^3.5.0",
    "trystero": "^0.22.0",
    "tw-animate-css": "^1.4.0",
    "typescript": "^5.9.3",
    "usehooks-ts": "^3.1.1",
    "uuid": "^13.0.0",
    "vite-plugin-babel-macros": "^1.0.6",
    "webrtc-adapter": "^9.0.4",
    "zod": "^4.3.6"
  },
  "scripts": {
    "start": "cross-env VITE_HOMEPAGE=$(npm pkg get homepage) vite --host 127.0.0.1 --port 3000",
    "start:tracker": "bittorrent-tracker",
    "start:streamsaver": "serve -p 3015 node_modules/streamsaver",
    "start:api": "node simple-api-server.js",
    "start:e2e": "node simple-api-server.js & npm run start:tracker & cross-env VITE_HOMEPAGE=$(npm pkg get homepage) VITE_IS_E2E_TEST=true VITE_RTC_CONFIG_ENDPOINT=/api/get-config VITE_TRACKER_URL=\"ws://localhost:8000\" vite --host 127.0.0.1 --port 3000 --logLevel error",
    "dev": "mprocs \"npx cross-env VITE_TRACKER_URL=ws://localhost:8000 VITE_STREAMSAVER_URL=http://localhost:3015/mitm.html VITE_RTC_CONFIG_ENDPOINT=/api/get-config npm run start\" \"npm run start:tracker\" \"npm run start:streamsaver\" \"npm run start:api\"",
    "build": "npm run build:app && npm run build:sdk",
    "build:app": "cross-env VITE_HOMEPAGE=$(npm pkg get homepage) vite build",
    "build:sdk": "cross-env VITE_HOMEPAGE=$(npm pkg get homepage) parcel build sdk/sdk.ts --no-content-hash",
    "build:sdk:watch": "nodemon --exec \"npm run build:sdk\"",
    "test": "vitest",
    "prepare": "husky install",
    "prettier": "prettier \"**/*.{ts,tsx}\" --write",
    "lint": "eslint src e2e --max-warnings=0 --fix",
    "check:types": "tsc && echo \"No type errors.\"",
    "generate-rtc-config": "node scripts/generate-rtc-config.cjs",
    "test:e2e": "playwright test --reporter=list",
    "test:e2e:report": "playwright show-report",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:debug": "playwright test --debug",
    "test:e2e:headed": "playwright test --headed",
    "test:e2e:codegen": "playwright codegen localhost:3000",
    "playwright:install": "playwright install --with-deps"
  },
  "eslintConfig": {
    "extends": [
      "react-app"
    ]
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.10.2",
    "@playwright/test": "^1.56.1",
    "@tailwindcss/vite": "^4.2.2",
    "@testing-library/jest-dom": "^6.7.0",
    "@types/bun": "latest",
    "@types/file-saver": "^2.0.7",
    "@types/node": "^18.19.71",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/react-syntax-highlighter": "^15.5.5",
    "@types/streamsaver": "^2.0.1",
    "@types/uuid": "^11.0.0",
    "@types/webtorrent": "^0.109.3",
    "@typescript-eslint/eslint-plugin": "^8.35.1",
    "@typescript-eslint/parser": "^8.35.1",
    "@vercel/node": "^5.3.0",
    "@vitejs/plugin-react": "^6.0.1",
    "bittorrent-tracker": "^11.2.2",
    "cross-env": "^7.0.3",
    "eslint": "^8.21.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-config-react-app": "^7.0.1",
    "eslint-plugin-import": "^2.26.0",
    "eslint-plugin-jsx-a11y": "^6.6.1",
    "eslint-plugin-prettier": "^5.1.3",
    "eslint-plugin-react": "^7.30.1",
    "eslint-plugin-react-hooks": "^4.6.0",
    "husky": "^8.0.1",
    "jsdom": "^24.0.0",
    "mprocs": "^0.8.3",
    "nodemon": "^3.0.1",
    "parcel": "^2.10.0",
    "playwright": "^1.56.1",
    "prettier": "^3.2.5",
    "pretty-quick": "^4.0.0",
    "process": "^0.11.10",
    "serve": "^14.2.5",
    "tailwindcss": "^4.2.2",
    "url": "^0.11.0",
    "util": "^0.12.5",
    "vercel": "^50.12.3",
    "vite": "^8.0.0",
    "vite-plugin-pwa": "^1.2.0",
    "vite-plugin-svgr": "^4.5.0",
    "vitest": "^4.1.0"
  },
  "overrides": {
    "ipfs-core": "npm:dry-uninstall"
  },
  "trustedDependencies": [
    "node-datachannel"
  ],
  "module": "src/index.tsx",
  "private": true,
  "peerDependencies": {
    "typescript": "^5"
  }
}
